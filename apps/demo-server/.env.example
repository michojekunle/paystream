# PayStream — Environment Variables
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git

# ─── Stacks Network ────────────────────────────────────────────────────────────
STACKS_NETWORK=testnet
STACKS_API_URL=https://api.testnet.hiro.so

# ─── Facilitator (deploy via render.yaml first) ───────────────────────────────
# The facilitator broadcasts Stacks transactions and confirms settlements.
FACILITATOR_URL=https://paystream-facilitator.onrender.com

# ─── Merchant ─────────────────────────────────────────────────────────────────
# Your Stacks address and private key (for signing/receiving payments)
MERCHANT_ADDRESS=ST<your_stacks_address>
MERCHANT_PRIVATE_KEY=<your_private_key_hex_64_chars>

# ─── Deployed Contracts (filled automatically by scripts/deploy-contracts.sh) ─
VAULT_CONTRACT=ST<deployer>.paystream-vault
ESCROW_CONTRACT=ST<deployer>.paystream-escrow
REGISTRY_CONTRACT=ST<deployer>.paystream-registry

# ─── Database (create project at https://supabase.com) ────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key_from_supabase_dashboard>

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=3402
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://paystream.io

# ─── AI (optional — for /api/ai/generate to use real GPT-4o-mini) ─────────────
# Without this, the endpoint returns a meaningful static protocol explanation.
OPENAI_API_KEY=sk-...

# ─── Vercel Frontends (NEXT_PUBLIC_ vars are exposed to the browser) ──────────
NEXT_PUBLIC_API_URL=https://paystream-api.onrender.com
NEXT_PUBLIC_FACILITATOR_URL=https://paystream-facilitator.onrender.com
NEXT_PUBLIC_NETWORK=testnet

# Read-only Supabase access for the dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key_from_supabase_dashboard>

# ─── Contract Deployment (never commit — only needed when deploying contracts) ─
DEPLOYER_PRIVATE_KEY=<testnet_deployer_key_hex>
DEPLOYER_MNEMONIC=<24 word mnemonic for testnet deployer>
# Get testnet STX: https://explorer.hiro.so/sandbox/faucet?chain=testnet
