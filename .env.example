# PayStream — Environment Variables
# Copy to .env.local and fill in your values
# Never commit .env.local to git

# ─── Demo Server ──────────────────────────────────────────────────────────────
PORT=3402
MERCHANT_ADDRESS=SP2PABAF9FTAJYNFZH93XENAJ8FVY99RRM50D2JG9
STACKS_NETWORK=testnet       # mainnet | testnet
ALLOWED_ORIGIN=http://localhost:3000

# ─── Stacks Node ─────────────────────────────────────────────────────────────
STACKS_API_URL=https://api.testnet.hiro.so

# ─── Wallet / Signing ─────────────────────────────────────────────────────────
# WARNING: For demo/testnet only. Never use mainnet keys here.
AGENT_PRIVATE_KEY=your_stacks_private_key_hex_here
AGENT_STX_ADDRESS=SP...your_stacks_address

# ─── Token Addresses (testnet) ────────────────────────────────────────────────
SBTC_CONTRACT_ADDRESS=SM3VDXK3WZZSA84XXFKAFAF15NNZX32CTSG82JFQ4
SBTC_CONTRACT_NAME=sbtc-token
USDC_CONTRACT_ADDRESS=SP3Y2ZSH8P7D50B0VBTSX11S7XSG24M1VB9YFQA4K
USDC_CONTRACT_NAME=token-usdcx

# ─── Dashboard ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEMO_API_URL=http://localhost:3402
NEXT_PUBLIC_NETWORK=testnet

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# POSTHOG_KEY=your_key_here
# SENTRY_DSN=your_dsn_here
